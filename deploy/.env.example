# Copy this file to deploy/.env and replace values before running compose.

DB_NAME=InShopDB
SA_PASSWORD=Change_me_Strong_Passw0rd!
JWT_KEY=change-me-minimum-32-characters-long-key
JWT_ISSUER=InShop
JWT_AUDIENCE=InShopAdmin
JWT_EXPIRATION_HOURS=8

FRONTEND_PORT=3000
API_PORT=5000
SQLSERVER_PORT=1433
REDIS_PORT=6379
EMBEDDING_PORT=8000
PAYMENTS_API_PORT=5001

PAYMENT_PROVIDER=YooKassa
YOOKASSA_SHOP_ID=replace-with-yookassa-shop-id
YOOKASSA_SECRET_KEY=replace-with-yookassa-secret-key
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_WEBHOOK_SECRET=replace-with-webhook-secret
YOOKASSA_IS_TEST_MODE=true
YOOKASSA_RETURN_URL=http://localhost:3000/payment-confirmation
YOOKASSA_NOTIFICATION_URL=http://localhost:5000/api/webhook/yookassa

AI_PROVIDER_TYPE=Yandex
AI_API_KEY=
AI_FOLDER_ID=
AI_MODEL_NAME=yandexgpt-lite
AI_TIMEOUT_SECONDS=60

EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
